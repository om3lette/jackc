class Main {
    function void main() {
        var Array a, b;

        let a = Array.new(10);
        let b = Array.new(5);

        let a[3] = 2;
        let a[4] = 8;
        let a[5] = 4;
        let b[a[3]] = a[3] + 3;                              // b[2] = 5
        let a[b[a[3]]] = a[a[5]] * b[((7 - a[3]) - 4) + 1];  // a[5] = 8 * 5 = 40
        return a[b[a[3]]];
    }
}
